.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  background-color: #f5f5f5;
}

.background-image {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
}

.background-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(255, 255, 255, 0.7);
  z-index: 2;
}

.content {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  max-width: 600rpx;
}

.title {
  font-size: 64rpx;
  font-weight: bold;
  color: #47bdf8;
  margin-bottom: 40rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.poem {
  padding: 32rpx 40rpx;
  border-radius: 16rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  max-width: 90%;
  width: 360rpx;
  text-align: center;
}

.poem-line {
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
  margin: 8rpx 0;
  font-style: italic;
}

.desc {
  text-align: center;
  margin: 40rpx 0;
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding: 0 40rpx;
}

.user-info {
  margin-top: 30rpx;
  padding: 24rpx;
  background-color: rgba(227, 242, 253, 0.9);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1976d2;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.btn {
  margin-top: 60rpx;
  width: 80%;
  max-width: 400rpx;
  border-radius: 24rpx;
  transition: all 0.3s ease;
  overflow: hidden;
}

.btn-primary {
  background-color: transparent;
  color: #1976d2;
  font-size: 32rpx;
  font-weight: 600;
  /* padding: 28rpx 0; */
  border: 1rpx solid rgba(187, 222, 251, 0.8);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 20rpx rgba(25, 118, 210, 0.1);
  position: relative;
  overflow: hidden;
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    to bottom right,
    rgba(255, 255, 255, 0.3) 0%,
    rgba(255, 255, 255, 0) 50%,
    rgba(255, 255, 255, 0.3) 100%
  );
  transform: rotate(45deg);
  animation: glassShine 3s infinite linear;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.btn-primary:hover {
  background-color: rgba(227, 242, 253, 0.3);
  box-shadow: 0 6rpx 24rpx rgba(25, 118, 210, 0.15);
  transform: translateY(-3rpx);
}

.btn-primary:hover::before {
  opacity: 1;
}

@keyframes glassShine {
  0% {
    transform: translateX(-100%) rotate(45deg);
  }
  100% {
    transform: translateX(100%) rotate(45deg);
  }
}

/* 响应式调整 */
@media (min-width: 768px) {
  .content {
    width: 80%;
    max-width: 500rpx;
  }
  
  .btn {
    width: 70%;
  }
}

@media (min-width: 1200px) {
  .content {
    width: 60%;
    max-width: 450rpx;
  }
  
  .btn {
    width: 60%;
  }
}
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

.card {
  width: 100%;
  max-width: 600rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.desc {
  text-align: center;
  margin: 40rpx 0;
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  padding: 0 20rpx;
}

.logo {
  margin: 40rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.logo image {
  width: 200rpx;
  height: 200rpx;
  object-fit: contain;
}

.user-info {
  margin-top: 20rpx;
  padding: 20rpx;
  background-color: #f0f9ff;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #1989fa;
  text-align: center;
}

.btn {
  margin-top: 40rpx;
  width: 80%;
  max-width: 400rpx;
}

/* 响应式调整 */
@media (min-width: 768px) {
  .card {
    width: 80%;
    max-width: 500rpx;
  }
  
  .btn {
    width: 70%;
  }
}

@media (min-width: 1200px) {
  .card {
    width: 60%;
    max-width: 450rpx;
  }
  
  .btn {
    width: 60%;
  }
}
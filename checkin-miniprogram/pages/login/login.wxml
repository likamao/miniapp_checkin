<view class="container">
  <!-- 背景图片 -->
  <view class="background-image">
    <image src="../../icons/login_back.jpg" mode="aspectFill"></image>
  </view>
  <!-- 半透明覆盖层 -->
  <view class="overlay"></view>
  <!-- 内容层 -->
  <view class="content">
    <view class="title">听 夏</view>
    <view class="poem">
      <view class="poem-line">Every day is a new beginning,</view>
      <view class="poem-line">Take a deep breath and start again.</view>
      <view class="poem-line">Small steps lead to big changes,</view>
      <view class="poem-line">Keep going, you've got this!</view>
    </view>
    <view class="desc">请使用微信登录以开始打卡</view>
<!--     
    <view wx:if="{{userInfo}}" class="user-info">
      <text>当前登录用户：{{userInfo.nickname || userInfo.nickName || '微信用户'}}</text>
    </view> -->
    <button class="btn btn-primary" bindtap="login">微信登录</button>
  </view>
  
  <!-- 个人信息完善弹框 -->
  <user-profile-modal 
    visible="{{showProfileModal}}"
    defaultNickname="{{defaultNickname}}"
    bind:close="onProfileModalClose"
    bind:confirm="onProfileModalConfirm"
  ></user-profile-modal>
</view>
<view class="container">
  <!-- 页面头部 - 海浪风格 -->
  <view class="header">
    <!-- 装饰气泡 -->
    <view class="header-bubble bubble-1"></view>
    <view class="header-bubble bubble-2"></view>
    <view class="header-bubble bubble-3"></view>

    <text class="page-title">今天也来打个小卡吗？(´･ω･`)♡</text>
    <text class="page-subtitle">不管今天怎样，你来过就闪闪发光✨</text>
    
    <!-- 波浪装饰 -->
    <view class="wave-decoration">
      <view class="wave-line"></view>
      <view class="wave-line"></view>
    </view>
  </view>

  <!-- 主题列表 -->
  <view class="topic-list" wx:if="{{topics.length > 0}}">
    <view wx:for="{{topics}}" wx:key="id" class="topic-card {{item.isExpired ? 'expired' : ''}}" bindtap="navigateToTopicDetail" data-topic-id="{{item.id}}">
      <view class="topic-header">
        <view class="topic-title-wrapper">
          <text class="topic-title">{{item.title}}</text>
        </view>
        <text class="topic-date">{{item.startDatetime}} 至 {{item.endDatetime}}</text>
      </view>
      <view class="topic-description">{{item.description}}</view>
      <view class="topic-footer">
        <text class="checkin-count">{{item.checkinCount}}人已打卡</text>
        <text class="checkin-status {{item.hasCheckedInToday ? '' : 'not-checked'}} {{item.isExpired ? 'expired-status' : ''}}">
          {{item.isExpired ? '已过期' : (item.hasCheckedInToday ? '今日已打卡' : '今日未打卡')}}
        </text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{topics.length === 0}}" class="empty">暂无主题</view>

  <!-- 主题列表 -->
  <view class="buttons-container">
    <!-- 发布主题按钮 -->
    <view wx:if="{{hasPublishPermission && token}}" class="action-button publish-button" bindtap="showPublishModal">
      <text class="action-button-text">发布主题</text>
    </view>
    <!-- 打卡按钮 -->
    <view class="action-button checkin-button" bindtap="showCheckinModal">
      <text class="action-button-text">打卡</text>
    </view>
    <!-- 报告按钮 -->
    <view wx:if="{{hasReportPermission && token}}" class="action-button report-button" bindtap="navigateToReport">
      <text class="action-button-text">报告</text>
    </view>
  </view>

  <!-- 发布主题弹框 - 海浪风格 -->
  <view wx:if="{{showPublishModal}}" class="modal-overlay" catchtap="hidePublishModal">
    <view class="modal-content" catchtap="stopPropagation">
      <!-- 弹窗头部 -->
      <view class="modal-header">
        <!-- 气泡装饰 -->
        <view class="modal-bubble modal-bubble-1"></view>
        <view class="modal-bubble modal-bubble-2"></view>
        <view class="modal-bubble modal-bubble-3"></view>
        
        <!-- 关闭按钮 -->
        <view class="modal-close" bindtap="hidePublishModal">×</view>
        
        <view class="modal-title">发布主题</view>
        
        <!-- 私密提示 - 仅 USER/VIEWER 角色可见 -->
        <view wx:if="{{isPrivateTopic}}" class="private-tip">
          <text class="private-tip-icon">🔒</text>
          <text class="private-tip-text">您创建的主题仅自己可见</text>
        </view>
        
        <!-- 波浪装饰 -->
        <view class="modal-wave-decoration">
          <view class="modal-wave-line"></view>
          <view class="modal-wave-line"></view>
        </view>
      </view>
      
      <view class="modal-body">
        <!-- 可见性选择 - 仅 PUBLISHER/ADMIN 角色可见 -->
        <view wx:if="{{canSelectVisibility}}" class="visibility-selector">
          <view class="visibility-options">
            <view 
              class="visibility-option {{!newTopic.isPrivate ? 'active' : ''}}" 
              bindtap="toggleVisibility" 
              data-private="false"
            >
              <view class="visibility-radio">
                <view class="visibility-radio-inner" wx:if="{{!newTopic.isPrivate}}"></view>
              </view>
              <text class="visibility-label-text">公开</text>
            </view>
            <view 
              class="visibility-option {{newTopic.isPrivate ? 'active' : ''}}" 
              bindtap="toggleVisibility" 
              data-private="true"
            >
              <view class="visibility-radio">
                <view class="visibility-radio-inner" wx:if="{{newTopic.isPrivate}}"></view>
              </view>
              <text class="visibility-label-text">私有</text>
            </view>
          </view>
        </view>
        
        <view class="form-item">
          <text class="form-label">主题标题</text>
          <view class="input-container">
            <textarea 
              class="form-input" 
              placeholder="请输入主题标题（10-100字）" 
              value="{{newTopic.title}}"
              bindinput="onTitleInput"
              maxlength="100"
              auto-height
              style="height: {{titleInputHeight}}rpx;"
            />
          </view>
          <text class="form-hint">{{newTopic.title.length}}/100</text>
        </view>
        <view class="form-item">
          <text class="form-label">主题描述</text>
          <view class="textarea-container">
            <textarea 
              class="form-textarea" 
              placeholder="请输入主题描述" 
              value="{{newTopic.description}}"
              bindinput="onDescriptionInput"
              maxlength="500"
              style="height: {{descriptionInputHeight}}rpx;"
            />
          </view>
          <text class="form-hint">{{newTopic.description.length}}/500</text>
        </view>
        
        <view class="form-item">
          <text class="form-label">主题有效期</text>
          <view class="duration-selector">
            <view 
              class="duration-option {{newTopic.durationUnit === 'week' ? 'active' : ''}}" 
              bindtap="selectDuration" 
              data-duration="week"
              data-days="7"
            >
              <view class="duration-radio">
                <view class="duration-radio-inner" wx:if="{{newTopic.durationUnit === 'week'}}"></view>
              </view>
              <text class="duration-label">周</text>
            </view>
            <view 
              class="duration-option {{newTopic.durationUnit === 'month' ? 'active' : ''}}" 
              bindtap="selectDuration" 
              data-duration="month"
              data-days="30"
            >
              <view class="duration-radio">
                <view class="duration-radio-inner" wx:if="{{newTopic.durationUnit === 'month'}}"></view>
              </view>
              <text class="duration-label">月</text>
            </view>
            <view 
              class="duration-option {{newTopic.durationUnit === 'year' ? 'active' : ''}}" 
              bindtap="selectDuration" 
              data-duration="year"
              data-days="365"
            >
              <view class="duration-radio">
                <view class="duration-radio-inner" wx:if="{{newTopic.durationUnit === 'year'}}"></view>
              </view>
              <text class="duration-label">年</text>
            </view>
          </view>
          <text class="form-hint">当前选择：{{newTopic.durationDays}}天</text>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="modal-button cancel" bindtap="hidePublishModal">取消</button>
        <button class="modal-button confirm" bindtap="publishTopic">发布</button>
      </view>
    </view>
  </view>

  <!-- 打卡弹框 - 海浪风格 -->
  <view wx:if="{{showCheckinModal}}" class="checkin-modal-overlay" catchtap="hideCheckinModal">
    <view class="checkin-modal-content" catchtap="stopPropagation">
      <!-- 加载状态 -->
      <view wx:if="{{checkinIsLoading}}" class="checkin-loading-container">
        <view class="checkin-loading-spinner"></view>
        <view class="checkin-loading-text">加载中...</view>
      </view>
      
      <!-- 已打卡状态 -->
      <view wx:elif="{{checkinHasCheckedInToday}}" class="checkin-card">
        <view class="checkin-checked-in">
          <view class="checkin-checked-in-icon">
            <image class="checkin-checked-in-image" src="../../icons/relax.png" mode="aspectFit"/>
          </view>
          <view class="checkin-checked-in-title">今日已打卡</view>
          <view class="checkin-checked-in-desc">{{checkinEncouragementText}}</view>
        </view>
      </view>
      
      <!-- 打卡表单 -->
      <view wx:else class="checkin-card">
        <view class="checkin-title">今日打卡</view>
        <scroll-view class="checkin-scroll-view" scroll-y="true" enhanced="true" show-scrollbar="{{false}}" enable-flex="{{true}}">
          <form bindsubmit="checkinSubmitCheckin">
            <view class="checkin-form-item">
              <text>选择主题</text>
              <view class="checkin-topic-selector">
                <block wx:if="{{checkinTopics.length > 0}}">
                  <view wx:for="{{checkinTopics}}" wx:key="id" class="checkin-topic-item" bindtap="checkinSelectTopic" data-topic-id="{{item.id}}">
                    <view class="checkin-topic-item-content {{checkinSelectedTopicId === item.id ? 'active' : ''}}">
                      <text>{{item.title}}</text>
                    </view>
                  </view>
                </block>
                <view wx:else class="empty-topics">暂无有效主题</view>
              </view>
            </view>
            <view class="checkin-form-item">
              <text>打卡标题</text>
              <input class="checkin-input" name="title" placeholder="请输入打卡标题" maxlength="50"/>
            </view>
            <view class="checkin-form-item">
              <text>打卡内容</text>
              <textarea class="textarea" name="content" placeholder="请输入打卡内容" maxlength="500" bindinput="checkinOnContentInput"/>
            </view>
            <view class="checkin-button-container">
              <button class="btn btn-primary" form-type="submit">提交打卡</button>
            </view>
          </form>
        </scroll-view>
      </view>
    </view>
  </view>

  <!-- 庆祝动画 -->
  <view wx:if="{{checkinShowCelebration}}" class="checkin-celebration">
    <view wx:for="{{checkinFireworks}}" wx:key="index" class="checkin-firework" style="left: {{item.left}}px; top: {{item.top}}px; animation-delay: {{item.delay}}s;">
      <view class="checkin-spark"></view>
    </view>
  </view>

  <!-- 分享弹窗 -->
  <view wx:if="{{showShareModal}}" class="share-modal-overlay" catchtap="hideShareModal">
    <view class="share-modal-content" catchtap="stopPropagation">
      <view class="share-modal-header">
        <view class="share-modal-title">分享打卡</view>
        <view class="share-modal-close" bindtap="hideShareModal">×</view>
      </view>
      <view class="share-modal-body">
        <view class="share-options">
          <view class="share-option" bindtap="shareToWechat">
            <view class="share-option-icon">👥</view>
            <view class="share-option-text">微信好友</view>
          </view>
          <view class="share-option" bindtap="shareToMoments">
            <view class="share-option-icon">📢</view>
            <view class="share-option-text">朋友圈</view>
          </view>
          <view class="share-option" bindtap="copyShareLink">
            <view class="share-option-icon">🔗</view>
            <view class="share-option-text">复制链接</view>
          </view>
        </view>
      </view>
    </view>
  </view>

</view>

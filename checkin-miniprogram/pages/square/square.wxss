.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.topic-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.topic-card {
  background-color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.topic-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.topic-header {
  margin-bottom: 16rpx;
}

.topic-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.topic-date {
  font-size: 20rpx;
  color: #999;
  display: block;
}

.topic-description {
  font-size: 24rpx;
  color: #666;
  line-height: 36rpx;
  margin-bottom: 20rpx;
}

.topic-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.checkin-count {
  font-size: 22rpx;
  color: #1989fa;
  font-weight: 500;
}

.checkin-status {
  font-size: 22rpx;
  color: #67c23a;
  font-weight: 500;
}

.checkin-status.not-checked {
  color: #999;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 24rpx;
}

/* 发布主题按钮样式 */
.publish-button-container {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  z-index: 999;
}

.publish-button {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background-color: #1989fa;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  border: 4rpx solid white;
  transition: all 0.3s ease;
}

.publish-button-text {
  font-size: 48rpx;
  font-weight: bold;
  line-height: 90rpx;
}

.publish-button:hover {
  background-color: #007aff;
  transform: scale(1.1);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.25);
}

.publish-button:active {
  transform: scale(0.95);
}

/* 发布主题弹框样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  padding: 40rpx;
  box-sizing: border-box;
}

.modal-content {
  width: 100%;
  max-width: 600rpx;
  background-color: white;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  overflow: hidden;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #e4e4e4;
  background-color: #f9f9f9;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
  padding: 8rpx;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.modal-close:hover {
  background-color: #e4e4e4;
}

.modal-body {
  padding: 32rpx;
  flex: 1;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.input-container {
  position: relative;
}

.textarea-container {
  position: relative;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e4e4e4;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  resize: none;
  line-height: 1.5;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #1989fa;
  box-shadow: 0 0 0 4rpx rgba(25, 137, 250, 0.1);
}

.form-textarea {
  width: 100%;
  padding: 20rpx;
  border: 2rpx solid #e4e4e4;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.5;
  transition: all 0.3s ease;
  overflow-y: auto;
}

.form-textarea:focus {
  border-color: #1989fa;
  box-shadow: 0 0 0 4rpx rgba(25, 137, 250, 0.1);
}

.form-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
  text-align: right;
}

.modal-footer {
  display: flex;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-top: 1rpx solid #e4e4e4;
  background-color: #f9f9f9;
  gap: 20rpx;
}

.modal-button {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.modal-button.cancel {
  background-color: #f5f5f5;
  color: #666;
}

.modal-button.confirm {
  background-color: #1989fa;
  color: white;
}

.modal-button.confirm:hover {
  background-color: #007aff;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(25, 137, 250, 0.3);
}

.modal-button.cancel:hover {
  background-color: #e4e4e4;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.modal-button:active {
  transform: translateY(0);
}

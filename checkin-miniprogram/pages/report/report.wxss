.report-container {
  padding: 20rpx;
  background-color: #ffffff;
  min-height: 100vh;
}

.report-header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.report-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.report-date-range {
  font-size: 24rpx;
  color: #666;
}

.report-type-selector {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
  gap: 20rpx;
}

.type-button {
  padding: 15rpx 40rpx;
  border: 2rpx solid #1989fa;
  border-radius: 50rpx;
  font-size: 28rpx;
  background-color: #fff;
  color: #1989fa;
}

.type-button.active {
  background-color: #1989fa;
  color: #fff;
}

.topic-selector {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.selector-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
}

.picker {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  padding: 10rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 5rpx;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

.error-container {
  padding: 30rpx;
  background-color: #fff1f0;
  border: 1rpx solid #ffccc7;
  border-radius: 10rpx;
  margin-bottom: 30rpx;
}

.error-text {
  font-size: 28rpx;
  color: #f5222d;
  text-align: center;
}

.report-content {
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
  border-left: 8rpx solid #1989fa;
  padding-left: 15rpx;
}

.metrics-section {
  margin-bottom: 40rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.metric-item {
  background-color: #f5f5f5;
  padding: 20rpx;
  border-radius: 10rpx;
  text-align: center;
}

.metric-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1989fa;
  display: block;
  margin-bottom: 10rpx;
}

.metric-label {
  font-size: 24rpx;
  color: #666;
}

.chart-section {
  margin-bottom: 40rpx;
}

.chart-container {
  height: 400rpx;
  background-color: #ffffff;
  border: 1rpx solid #e8e8e8;
  border-radius: 10rpx;
  padding: 20rpx;
}

.chart {
  width: 100%;
  height: 100%;
}

.user-section {
  margin-bottom: 40rpx;
}

.user-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.user-item {
  padding: 20rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.user-basic-info {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.user-rank {
  font-size: 28rpx;
  font-weight: bold;
  color: #1989fa;
  margin-right: 20rpx;
  width: 50rpx;
}

.user-info {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.user-stats {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  padding-left: 70rpx;
}

.user-checkin-count {
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
}

.user-consecutive-days {
  font-size: 24rpx;
  color: #666;
}

/* 详细打卡记录样式 */
.checkin-details {
  margin-top: 20rpx;
  padding-left: 60rpx;
  border-left: 2rpx solid #e8e8e8;
}

.checkin-detail-item {
  margin-bottom: 20rpx;
  padding: 15rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.checkin-date {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.checkin-title {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.checkin-content {
  display: block;
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-button {
  flex: 1;
  padding: 20rpx;
  font-size: 28rpx;
  border-radius: 10rpx;
  background-color: #1989fa;
  color: #fff;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .metrics-grid {
    grid-template-columns: 1fr;
  }
  
  .chart-container {
    height: 300rpx;
  }
  
  .action-buttons {
    flex-direction: column;
  }
}
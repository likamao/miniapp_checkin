<view class="container">
  <view wx:if="{{isLoading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>
  
  <view wx:else class="topic-detail">
    <view class="topic-header">
      <view class="topic-title-row">
        <view class="topic-title">{{topic.title}}</view>
        <view wx:if="{{isTopicCreator}}" class="edit-button" bindtap="showEditModal">
          <text class="edit-icon">✏️</text>
          <text class="edit-text">编辑</text>
        </view>
      </view>
      <view class="topic-meta">
        <text class="topic-date">{{topic.startDatetime}} 至 {{topic.endDatetime}}</text>
        <text class="topic-checkin-count">{{topic.checkinCount}}人已打卡</text>
      </view>
    </view>
    
    <view class="topic-description">
      <text class="section-title">主题描述</text>
      <text class="description-text">{{topic.description || '暂无描述'}}</text>
    </view>
    
    <view class="topic-status">
      <text class="section-title">打卡状态</text>
      <view class="status-info">
        <text wx:if="{{topic.hasCheckedInToday}}" class="status-checked">今日已打卡</text>
        <text wx:else class="status-unchecked">今日未打卡</text>
      </view>
    </view>
    
    <view class="action-section">
      <button wx:if="{{!topic.hasCheckedInToday && !isTopicExpired}}" class="btn btn-primary" bindtap="showCheckinModal">立即打卡</button>
      <button wx:elif="{{isTopicExpired}}" class="btn btn-expired" disabled>主题已过期</button>
      <button wx:else class="btn btn-disabled" disabled>今日已打卡</button>
    </view>
    
    <view class="checkin-records">
      <text class="section-title">打卡记录</text>
      <view class="record-list">
        <view wx:for="{{records}}" wx:key="id" class="record-item">
          <view class="record-user">{{item.nickname || '微信用户'}}</view>
          <view class="record-info">
            <text class="record-date">{{item.checkinDate}}</text>
            <text class="record-consecutive">连续{{item.consecutiveDays}}天</text>
          </view>
        </view>
        <view wx:if="{{records.length === 0}}" class="empty-records">暂无打卡记录</view>
      </view>
    </view>
  </view>
  
  <!-- 打卡弹窗 - 海浪风格 -->
  <view wx:if="{{showCheckinModal}}" class="modal-overlay" bindtap="hideCheckinModal">
    <view class="modal-content" catchtap="stopPropagation">
      <!-- 弹窗头部 -->
      <view class="modal-header">
        <!-- 气泡装饰 -->
        <view class="modal-bubble modal-bubble-1"></view>
        <view class="modal-bubble modal-bubble-2"></view>
        <view class="modal-bubble modal-bubble-3"></view>
        
        <!-- 关闭按钮 -->
        <view class="modal-close" bindtap="hideCheckinModal">×</view>
        
        <view class="modal-title">主题打卡</view>
        
        <!-- 波浪装饰 -->
        <view class="modal-wave-decoration">
          <view class="modal-wave-line"></view>
          <view class="modal-wave-line"></view>
        </view>
      </view>
      
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">打卡标题</text>
          <view class="input-container">
            <input 
              class="form-input" 
              placeholder="请输入打卡标题（50字以内）" 
              maxlength="50" 
              bindinput="onCheckinTitleInput" 
              value="{{checkinForm.title}}" 
            />
          </view>
        </view>
        <view class="form-item">
          <text class="form-label">打卡内容</text>
          <view class="textarea-container">
            <textarea 
              class="form-textarea" 
              placeholder="请输入打卡内容（500字以内）" 
              maxlength="500" 
              bindinput="onCheckinContentInput" 
              value="{{checkinForm.content}}" 
            />
          </view>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="modal-button cancel" bindtap="hideCheckinModal">取消</button>
        <button class="modal-button confirm" bindtap="submitCheckin">提交</button>
      </view>
    </view>
  </view>
  
  <!-- 成功弹窗 - 海浪风格 -->
  <view wx:if="{{showSuccessModal}}" class="success-modal-overlay" bindtap="hideSuccessModal">
    <view class="success-modal-content" catchtap="stopPropagation">
      <view class="success-icon">✓</view>
      <view class="success-title">打卡成功！</view>
      <view class="success-info">
        <text>当前已有 {{checkinResult.checkinCount}} 人打卡</text>
        <text>你已连续打卡 {{checkinResult.consecutiveDays}} 天</text>
      </view>
      <button class="success-button" bindtap="hideSuccessModal">确定</button>
    </view>
  </view>
  
  <!-- 编辑主题弹窗 - 海浪风格 -->
  <view wx:if="{{showEditModal}}" class="modal-overlay" bindtap="hideEditModal">
    <view class="modal-content" catchtap="stopPropagation">
      <!-- 弹窗头部 -->
      <view class="modal-header">
        <!-- 气泡装饰 -->
        <view class="modal-bubble modal-bubble-1"></view>
        <view class="modal-bubble modal-bubble-2"></view>
        <view class="modal-bubble modal-bubble-3"></view>
        
        <!-- 关闭按钮 -->
        <view class="modal-close" bindtap="hideEditModal">×</view>
        
        <view class="modal-title">编辑主题</view>
        
        <!-- 波浪装饰 -->
        <view class="modal-wave-decoration">
          <view class="modal-wave-line"></view>
          <view class="modal-wave-line"></view>
        </view>
      </view>
      
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">主题标题</text>
          <view class="input-container">
            <input 
              class="form-input" 
              placeholder="请输入主题标题（10-100 字）" 
              maxlength="100" 
              bindinput="onEditTitleInput" 
              value="{{editForm.title}}" 
            />
          </view>
          <text class="form-hint">{{editForm.title.length}}/100</text>
        </view>
        <view class="form-item">
          <text class="form-label">主题描述</text>
          <view class="textarea-container">
            <textarea 
              class="form-textarea" 
              placeholder="请输入主题描述（500 字以内）" 
              maxlength="500" 
              bindinput="onEditDescriptionInput" 
              value="{{editForm.description}}" 
            />
          </view>
          <text class="form-hint">{{editForm.description.length}}/500</text>
        </view>
      </view>
      
      <view class="modal-footer">
        <button class="modal-button cancel" bindtap="hideEditModal">取消</button>
        <button class="modal-button confirm" bindtap="saveEditTopic">保存</button>
      </view>
    </view>
  </view>
</view>

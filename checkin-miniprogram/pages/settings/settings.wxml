<view class="container">
  <!-- 页面头部 - 海浪风格 -->
  <view class="header">
    <!-- 装饰气泡 -->
    <view class="header-bubble bubble-1"></view>
    <view class="header-bubble bubble-2"></view>
    <view class="header-bubble bubble-3"></view>
    
    <!-- wxml -->
    <text class="page-title">悄悄改改？(つ´ω`)つ</text>
    <!-- <text class="page-subtitle">不管今天怎样，你来过就闪闪发光✨</text> -->
    
    <!-- 波浪装饰 - 与弹框一致 -->
    <view class="wave-decoration">
      <view class="wave-line"></view>
      <view class="wave-line"></view>
    </view>
  </view>
  
  <!-- 设置列表 -->
  <view class="settings-list">
    <!-- 个人信息设置 -->
    <view class="setting-item" bindtap="onEditProfile">
      <view class="setting-info">
        <text class="setting-title">个人信息</text>
        <text class="setting-desc">修改您的昵称</text>
      </view>
      <view class="setting-arrow">›</view>
    </view>
    
    <!-- 隐私开关 -->
    <view class="setting-item">
      <view class="setting-info">
        <text class="setting-title">匿名化</text>
        <text class="setting-desc">开启后，您的打卡数据将匿名纳入整体统计（仅显示总数、平均值等，不含任何个人信息）</text>
      </view>
      <switch 
        class="setting-switch" 
        checked="{{allowStatsDisplay}}" 
        bindchange="onAllowStatsDisplayChange"
        color="#1976d2"
      />
    </view>
  </view>
  
  <!-- 数据设置 -->
  <view class="tips">
    <text class="tips-title">{{dataSettingsTitle}}</text>
    <block wx:for="{{dataSettings}}" wx:key="index">
      <text class="tips-text">{{item.text}}</text>
    </block>
  </view>

  
  <!-- 个人信息修改弹框 -->
  <user-profile-modal 
    visible="{{showProfileModal}}"
    defaultNickname="{{defaultNickname}}"
    currentNickname="{{currentNickname}}"
    bind:close="onProfileModalClose"
    bind:confirm="onProfileModalConfirm"
  ></user-profile-modal>
  <view class="wave-footer"></view>
</view>

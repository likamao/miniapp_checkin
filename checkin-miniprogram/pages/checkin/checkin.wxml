<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{isLoading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载中...</view>
  </view>
  
  <!-- 打卡界面 -->
  <view wx:else class="card">
    <view class="title">每日打卡</view>
    <!-- 未打卡状态 -->
    <form wx:if="{{!hasCheckedInToday}}" bindsubmit="submitCheckin">
      <view class="form-item">
        <text>打卡标题</text>
        <input class="input" name="title" placeholder="请输入打卡标题（50字以内）" maxlength="50" required />
      </view>
      <view class="form-item">
        <text>打卡内容</text>
        <textarea class="textarea" name="content" placeholder="请输入打卡内容（500字以内）" maxlength="500" required bindinput="onContentInput" />
      </view>
      <view class="form-item">
        <text>选择主题</text>
        <view class="topic-selector">
          <view wx:for="{{topics}}" wx:key="id" class="topic-item" bindtap="selectTopic" data-topic-id="{{item.id}}">
            <view class="topic-item-content" style="border-color: {{selectedTopicId == item.id ? '#1989fa' : '#e4e4e4'}}; background-color: {{selectedTopicId == item.id ? '#f0f9ff' : 'white'}};">
              <text style="color: {{selectedTopicId == item.id ? '#1989fa' : '#333'}};">{{item.title}}</text>
            </view>
          </view>
        </view>
      </view>
      <button class="btn btn-primary" form-type="submit">提交打卡</button>
    </form>
    <!-- 已打卡状态 -->
    <view wx:else class="checked-in">
      <view class="checked-in-icon">
        <image class="checked-in-image" src="icons/relax.png" />
      </view>

      <view class="checked-in-title">今日已打卡</view>
      <view class="checked-in-desc">{{encouragementText}}</view>
    </view>
  </view>
  <!-- 庆祝动画 -->
  <view wx:if="{{showCelebration}}" class="celebration">
    <view class="firework" wx:for="{{fireworks}}" wx:key="index" style="left: {{item.left}}px; top: {{item.top}}px; animation-delay: {{item.delay}}s;">
      <view class="spark" wx:for="{{10}}" wx:key="sparkIndex" style="transform: rotate({{36 * sparkIndex}}deg);"></view>
    </view>
  </view>
</view>
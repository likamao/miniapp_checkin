}

/* 响应式调整 */
@media (min-width: 768px) {
  .container {
    padding: 48rpx;
  }
  
  .header {
    margin: -48rpx -48rpx 48rpx -48rpx;
    padding: 64rpx 48rpx 80rpx;
  }
  
  .filter-card,
  .records-card,
  .bottom-tip {
    max-width: 720rpx;
    margin-left: auto;
    margin-right: auto;
  }
  
  .modal-content {
    width: 80%;
    max-width: 600rpx;
  }
}

@media (min-width: 1200px) {
  .modal-content {
    width: 60%;
    max-width: 560rpx;
  }
}

}

.modal-body {
  padding: 32rpx;
  flex: 1;
  overflow-y: auto;
  max-height: 50vh;
  background: #ffffff;
}

.modal-content-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  word-break: break-word;

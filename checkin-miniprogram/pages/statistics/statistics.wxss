.container {
  padding: 20rpx;
}

.settings-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.settings-entry-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.settings-entry-icon {
  font-size: 40rpx;
  color: #999;
  font-weight: 300;
}

.month-info {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.week-info {
  text-align: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.stat-cards {
  display: flex;
  justify-content: space-between;
  margin: 20rpx 0;
}

.stat-card {
  background-color: #e3f2fd;
  border-radius: 8px;
  padding: 20rpx;
  text-align: center;
  flex: 1;
  margin: 0 10rpx;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1976d2;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

.progress-section {
  margin: 30rpx 0;
}

.progress-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

.progress-bar {
  width: 100%;
  height: 20rpx;
  background-color: #e0e0e0;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-bar-fill {
  height: 100%;
  background-color: #1976d2;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: right;
  font-size: 24rpx;
  color: #666;
}

.stat-info {
  margin-top: 20rpx;
  text-align: center;
}

.stat-desc {
  font-size: 28rpx;
  color: #666;
}
